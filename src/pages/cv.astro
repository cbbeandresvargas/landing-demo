---
import "../styles/global.css";
import cvData from "../data.json";
const { personal, education, experience, saas_projects, skills } = cvData;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>CV - {personal.name}</title>
		<style>
			@page {
				size: letter;
				margin: 0.5in;
			}
			body {
				/*font-family: 'Times New Roman', Times, serif;*/
				line-height: 1.2;
				color: #000;
			}
			.section-title {
				border-bottom: 1px solid #000;
				letter-spacing: 0.05em;
				margin-top: 1rem;
				margin-bottom: 0.25rem;
			}
			@media print {
				.no-print {
					display: none;
				}
				body {
					background: white;
					padding: 0;
				}
				.paper {
					box-shadow: none;
					margin: 0;
					width: 100%;
				}
			}
		</style>
	</head>
	<body class="bg-gray-200 py-10">
		<div class="no-print fixed bottom-8 right-8 z-50">
			<button
				onclick="window.print()"
				class="flex items-center gap-2 rounded-full bg-black px-6 py-3 text-white shadow-lg transition-transform hover:scale-105 active:scale-95">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
					></path>
				</svg>
				<span>Imprimir / Descargar PDF</span>
			</button>
		</div>
		<main class="paper mx-auto min-h-[11in] max-w-[8.5in] bg-white p-[0.75in] shadow-2xl">
			<header class="mb-4 text-center">
				<h1 class="text-2xl font-bold uppercase tracking-tight">
					{personal.name}
				</h1>
				<div class="mt-1 text-[11pt]">
					<p>{personal.contact}</p>
					<div class="flex justify-center gap-2 italic">
						{
							personal.links.map((link, index) => (
								<>
									<a href={link.url} target="_blank" class="text-black no-underline hover:underline">
										{link.label}
									</a>
									{index < personal.links.length - 1 && <span>•</span>}
								</>
							))
						}
					</div>
				</div>
			</header>

			<section>
				<h2 class="section-title text-[12pt] font-bold uppercase">Education</h2>
				{
					education.map((edu) => (
						<div class="mt-2 text-[11pt]">
							<div class="flex items-baseline justify-between font-bold">
								<span>{edu.school}</span>
								<span>{edu.location}</span>
							</div>
							<div class="flex items-baseline justify-between italic">
								<span>{edu.degree}</span>
								<span>{edu.date}</span>
							</div>
							{edu.honors && <p class="mt-1">{edu.honors}</p>}
						</div>
					))
				}
			</section>

			<section>
				<h2 class="section-title text-[12pt] font-bold uppercase">Experience</h2>
				{
					experience.map((exp) => (
						<div class="mt-3 text-[11pt]">
							<div class="flex items-baseline justify-between">
								<span class="font-bold uppercase tracking-tight">{exp.org}</span>
								<span class="font-bold">{exp.location}</span>
							</div>
							<div class="mb-1 flex items-baseline justify-between italic">
								<span>{exp.role}</span>
								<span>{exp.date}</span>
							</div>
							<p class="text-justify italic leading-tight">{exp.description}</p>
						</div>
					))
				}
			</section>

			<section>
				<h2 class="section-title text-[12pt] font-bold uppercase">Projects & SaaS Development</h2>
				{
					saas_projects.map((proj) => (
						<div class="mt-3 text-[11pt]">
							<div class="flex items-baseline justify-between font-bold">
								<span>{proj.name}</span>
							</div>
							<p class="mt-1 text-justify italic leading-tight">{proj.description}</p>
						</div>
					))
				}
			</section>

			<section>
				<h2 class="section-title text-[12pt] font-bold uppercase">Skills & Interests</h2>
				<div class="mt-2 space-y-1 text-[11pt]">
					<p><strong>Technical:</strong> {skills.technical}</p>
					<p>
						<strong>Frameworks & Tools:</strong>
						{skills.frameworks}
					</p>
					<p><strong>Languages:</strong> {skills.languages}</p>
					{
						skills.interests && (
							<p>
								<strong>Interests:</strong> {skills.interests}
							</p>
						)
					}
				</div>
			</section>
		</main>
	</body>
</html>
