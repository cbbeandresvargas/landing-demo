---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
	.filter(post => (post.data.lang || "en") === lang)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout seo={{ title: t("blog") }}>
	<section class="section home-dark-section min-h-screen py-20">
		<div class="col-span-12 mx-auto max-w-6xl px-6">
			<h1 class="mb-4 text-5xl font-bold text-white lg:text-7xl">{t("blog")}</h1>
			<p class="mb-12 text-xl text-slate-400">Insights into software development, architecture, and tech entrepreneurship.</p>

			<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				{
					posts.map((post) => (
						<a href={`/blog/${post.slug}/`} class="group relative overflow-hidden rounded-2xl bg-zinc-900 transition-all hover:-translate-y-2">
							<div class="aspect-video overflow-hidden">
								<img 
									src={post.data.heroImage || "/images/blog-placeholder.png"} 
									alt={post.data.title}
									class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
								/>
							</div>
							<div class="p-6">
								<div class="flex gap-2 mb-3">
									{post.data.tags.map(tag => (
										<span class="text-xs font-mono text-blue-400 uppercase">{tag}</span>
									))}
								</div>
								<h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">{post.data.title}</h2>
								<p class="mt-2 text-sm text-slate-400 line-clamp-2">{post.data.description}</p>
								<div class="mt-4 text-xs text-slate-500">
									{post.data.pubDate.toLocaleDateString(lang, {
										year: 'numeric',
										month: 'long',
										day: 'numeric'
									})}
								</div>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>
