---
import { getLangFromUrl } from "@i18n/utils";
import { getExperience } from "@utils/data";

const lang = getLangFromUrl(Astro.url);
const experienceData = getExperience(lang);
---

<!-- Experience Timeline -->
<section class="experience-timeline section py-20">
	<div class="col-span-12">
		<div class="max-w-4xl mx-auto">
			<div class="space-y-16">
				{experienceData.map((experience) => (
					<div class="experience-item border-l-2 border-slate-300 pl-8 relative">
						<div class="absolute -left-2 top-0 w-4 h-4 bg-slate-300 rounded-full"></div>
						<div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200">
							<div class="flex items-center justify-between mb-4">
								<h3 class="text-2xl font-bold text-black">{experience.title}</h3>
								{experience.isCurrent && (
									<span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">
										{lang === 'es' ? 'Actual' : 'Current'}
									</span>
								)}
							</div>
							<p class="text-lg text-slate-600 mb-2">{experience.company}</p>
							<p class="text-sm text-slate-500 mb-4">{experience.period}</p>
							<p class="text-slate-700 mb-6">{experience.description}</p>
							<div class="space-y-2">
								<h4 class="font-semibold text-slate-900">
									{lang === 'es' ? 'Logros Clave:' : 'Key Achievements:'}
								</h4>
								<ul class="list-disc list-inside text-slate-600 space-y-1">
									{experience.achievements.map((achievement) => (
										<li>{achievement}</li>
									))}
								</ul>
							</div>
							{experience.technologies.length > 0 && (
								<div class="mt-4">
									<h4 class="font-semibold text-slate-900 mb-2">
										{lang === 'es' ? 'Tecnologías:' : 'Technologies:'}
									</h4>
									<div class="flex flex-wrap gap-2">
										{experience.technologies.map((tech) => (
											<span class="bg-slate-100 text-slate-700 px-3 py-1 rounded text-sm">{tech}</span>
										))}
									</div>
								</div>
							)}
						</div>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	function init() {
		const items = document.querySelectorAll('.experience-timeline .experience-item');
		
		items.forEach((item, index) => {
			const dot = item.querySelector('.absolute');
			const card = item.querySelector('.bg-white');

			const tl = gsap.timeline({
				scrollTrigger: {
					trigger: item,
					start: "top 85%",
					toggleActions: "play none none reverse"
				}
			});

			tl.from(dot, {
				duration: 0.6,
				scale: 0,
				ease: "back.out(1.7)"
			})
			.from(card, {
				duration: 1,
				xPercent: index % 2 === 0 ? -10 : 10, // Slight horizontal movement for interest
				y: 30,
				opacity: 0,
				ease: "power4.out"
			}, "-=0.3");
		});
	}

	document.addEventListener("DOMContentLoaded", init);
</script>
