---
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils";
import { getProjects } from "@utils/projects";
import fs from 'node:fs';
import path from 'node:path';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { class: className } = Astro.props;

const allProjects = getProjects(lang).map(p => {
	let hasImage = false;
	if (p.image && p.image !== "project-template.jpg" && p.image !== "" && p.image !== null && !p.image.includes("logomodeltemplate.png")) {
		// Check if file exists in public folder
		const imagePath = p.image.startsWith("/") 
			? path.join(process.cwd(), 'public', p.image)
			: path.join(process.cwd(), 'public', 'assets', 'images', 'projects', p.image);
		
		if (fs.existsSync(imagePath)) {
			hasImage = true;
		}
	}

	return {
		...p,
		hasImage
	};
}).sort((a, b) => {
	// 1. Prioritize projects with images
	if (a.hasImage && !b.hasImage) return -1;
	if (!a.hasImage && b.hasImage) return 1;
	// 2. Sort by date descending
	return new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime();
}).slice(0, 4); // Show only the first 4 projects with images if possible
---

<section id="projects" class:list={["section work-preview-section home-dark-section py-12", className]}>
	<div class="col-span-12 col-start-1 mx-auto max-w-7xl">
		<h2 class="sr-only">{t("projects")}</h2>
		<ol class="grid grid-cols-1 gap-24 md:grid-cols-2 lg:gap-44">
			{
				allProjects.map((project, index) => (
					<li
						class={
							index % 2 === 0
								? `md:col-start-1 md:row-start-${Math.floor(index / 2) * 2 + 1} md:row-span-2`
								: `md:col-start-2 md:row-start-${Math.floor(index / 2) * 2 + 2} md:row-span-2`
						}>
						<a href={translatePath(`/work/${project.id}`)} class="group block">
							<div class="relative overflow-hidden rounded-lg">
								<img
									src={project.image.startsWith("/") ? project.image : `/assets/images/projects/${project.image}`}
									alt={project.title}
									class="h-48 w-full bg-[#1c1917] object-contain p-6 transition-transform duration-300 group-hover:scale-105"
								/>
								<div class="absolute inset-0 flex items-center justify-center bg-black bg-opacity-0 transition-all duration-300 group-hover:bg-opacity-30">
									<h3 class="text-xl font-bold text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
										{project.title}
									</h3>
								</div>
							</div>
						</a>
					</li>
				))
			}
		</ol>
	</div>
</section>

<style is:global>
	.work-preview-section ol li img {
		--clip: 0%;
		clip-path: inset(var(--clip) round 0.5rem);
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	function init() {
		const projects = gsap.utils.toArray(".work-preview-section ol li") as gsap.DOMTarget[];
		const previews = gsap.utils.toArray(".work-preview-section ol li img") as gsap.DOMTarget[];
		previews.forEach((preview) => {
			gsap.from(preview, {
				scrollTrigger: {
					trigger: preview,
					start: "top bottom",
					end: "center center",
					scrub: 1,
					markers: false,
				},
				ease: "power3.out",
				"--clip": "30%",
			});
		});

		gsap.to(".home-dark-section", {
			scrollTrigger: {
				trigger: ".work-preview-section",
				start: "bottom bottom",
				end: "bottom 70%",
				scrub: 0.5,
				markers: false,
				immediateRender: false,
			},
			ease: "none",
			backgroundColor: "#18181b",
			color: "#fff",
		});

		if (window.innerWidth >= 768) {
			projects.forEach((project) => {
				gsap.to(project, {
					scrollTrigger: {
						trigger: ".work-preview-section ol",
						start: "top bottom",
						end: "bottom center",
						scrub: 1,
						markers: false,
					},
					ease: "none",
					y: `-200px`,
				});
			});
		}
	}

	document.removeEventListener("DOMContentLoaded", init); // astro:page-load
	document.addEventListener("DOMContentLoaded", init); // astro:page-load
</script>
