---
// ProjectsGrid.astro - Projects grid section for Projects page
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";
import { getProjects } from "@utils/projects";
import fs from 'node:fs';
import path from 'node:path';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const allProjects = getProjects(lang).map(p => {
	let hasImage = false;
	if (p.image && p.image !== "project-template.jpg" && p.image !== "" && p.image !== null && !p.image.includes("logomodeltemplate.png")) {
		// Check if file exists in public folder
		const imagePath = p.image.startsWith("/") 
			? path.join(process.cwd(), 'public', p.image)
			: path.join(process.cwd(), 'public', 'assets', 'images', 'projects', p.image);
		
		if (fs.existsSync(imagePath)) {
			hasImage = true;
		}
	}

	return {
		...p,
		hasImage
	};
}).sort((a, b) => {
	// 1. Prioritize projects with images
	if (a.hasImage && !b.hasImage) return -1;
	if (!a.hasImage && b.hasImage) return 1;
	// 2. Sort by date descending
	return new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime();
});
---

<!-- Projects Grid -->
<section class="projects-grid section bg-slate-50 py-20">
	<div class="col-span-12">
		<div class="mx-auto max-w-7xl px-4">
			<div id="projects-container" class="grid min-h-[600px] grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
				<!-- Projects will be rendered here by client-side script -->
			</div>

			<!-- Pagination Controls -->
			<div class="mt-16 flex items-center justify-center gap-4" id="pagination-controls">
				<button
					id="prev-page"
					class="rounded-full border border-slate-300 px-6 py-2 text-slate-600 transition-all hover:bg-slate-900 hover:text-white disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-slate-600">
					{lang === "es" ? "← Anterior" : "← Previous"}
				</button>
				<span id="page-info" class="font-mono text-sm text-slate-500">
					<!-- Page info will be here -->
				</span>
				<button
					id="next-page"
					class="rounded-full border border-slate-300 px-6 py-2 text-slate-600 transition-all hover:bg-slate-900 hover:text-white disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-slate-600">
					{lang === "es" ? "Siguiente →" : "Next →"}
				</button>
			</div>
		</div>
	</div>
</section>

<script define:vars={{ allProjects, lang, translatePath }}>
	window.allProjectsData = allProjects;
	window.currentLang = lang;
	window.translatePath = translatePath;
</script>

<script>
	import { gsap } from "gsap";

	let currentPage = 1;
	const itemsPerPage = 9;
	const allProjects = (window as any).allProjectsData;
	const lang = (window as any).currentLang;
	const translatePath = (window as any).translatePath;
	const totalPages = Math.ceil(allProjects.length / itemsPerPage);

	function renderProjects(page: number) {
		const container = document.getElementById("projects-container");
		if (!container) return;

		const start = (page - 1) * itemsPerPage;
		const end = start + itemsPerPage;
		const pageProjects = allProjects.slice(start, end);

		// GSAP Fade out out old items
		const oldItems = container.querySelectorAll(".project-card");
		if (oldItems.length > 0) {
			const tl = gsap.timeline({
				onComplete: () => {
					container.innerHTML = "";
					createNewItems(pageProjects);
				},
			});
			tl.to(oldItems, { duration: 0.3, opacity: 0, y: 20, stagger: 0.05, ease: "power2.in" });
		} else {
			createNewItems(pageProjects);
		}
	}

	function createNewItems(projects: any[]) {
		const container = document.getElementById("projects-container");
		if (!container) return;

		projects.forEach((project) => {
			const card = document.createElement("div");
			card.className = "project-card bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden group opacity-0 translate-y-10";

			const imageHtml = project.hasImage
				? `<div class="aspect-video overflow-hidden bg-[#1c1917] flex items-center justify-center p-6">
						<img 
							src="${project.image.startsWith("/") ? project.image : `/assets/images/projects/${project.image}`}" 
							alt="${project.title}" 
							class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" 
						/>
				   </div>`
				: `<div class="aspect-video overflow-hidden bg-gradient-to-br from-slate-100 to-slate-200 flex flex-col items-center justify-center p-8 text-center border-b border-slate-100">
						<div class="w-12 h-12 rounded-full bg-white/50 flex items-center justify-center mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
						</div>
						<span class="text-xs font-mono text-slate-400 uppercase tracking-widest">${project.technologies[0] || "Solution"}</span>
				   </div>`;

			card.innerHTML = `
				${imageHtml}
				<div class="p-8">
					<h3 class="text-xl font-bold mb-3 font-display text-slate-900 group-hover:text-blue-600 transition-colors">${project.title}</h3>
					<p class="text-slate-600 mb-6 line-clamp-2 text-sm leading-relaxed">${project.description}</p>
					<div class="flex items-center justify-between pt-4 border-t border-slate-50">
						<a 
							href="${translatePath + "work/" + project.id}"
							class="text-slate-900 hover:text-blue-600 font-bold text-xs uppercase tracking-wider transition-colors inline-flex items-center gap-2"
						>
							${lang === "es" ? "Ver Proyecto" : "View Project"}
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
						</a>
						<span class="text-[10px] font-mono text-slate-300">${new Date(project.pubDate).getFullYear()}</span>
					</div>
				</div>
			`;
			container.appendChild(card);
		});

		// Animate new items
		gsap.to(container.querySelectorAll(".project-card"), {
			duration: 0.6,
			opacity: 1,
			y: 0,
			stagger: 0.1,
			ease: "power2.out",
		});

		updatePagination();
	}

	function updatePagination() {
		const prevBtn = document.getElementById("prev-page");
		const nextBtn = document.getElementById("next-page");
		const pageInfo = document.getElementById("page-info");

		if (prevBtn) (prevBtn as HTMLButtonElement).disabled = currentPage === 1;
		if (nextBtn) (nextBtn as HTMLButtonElement).disabled = currentPage === totalPages;
		if (pageInfo) pageInfo.textContent = `${lang === "es" ? "Página" : "Page"} ${currentPage} / ${totalPages}`;
	}

	// Event Listeners
	document.getElementById("prev-page")?.addEventListener("click", () => {
		if (currentPage > 1) {
			currentPage--;
			renderProjects(currentPage);
			window.scrollTo({ top: (document.getElementById("projects-container")?.offsetTop || 0) - 100, behavior: "smooth" });
		}
	});

	document.getElementById("next-page")?.addEventListener("click", () => {
		if (currentPage < totalPages) {
			currentPage++;
			renderProjects(currentPage);
			window.scrollTo({ top: (document.getElementById("projects-container")?.offsetTop || 0) - 100, behavior: "smooth" });
		}
	});

	// Initial render
	renderProjects(1);
</script>

<style>
	.projects-grid {
		background-image: radial-gradient(circle at 2px 2px, #e2e8f0 1px, transparent 0);
		background-size: 40px 40px;
	}
</style>
