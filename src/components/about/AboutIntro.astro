---
// AboutIntro.astro - Introduction section for About page
import { getLangFromUrl } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<!-- Introduction Section -->
<section class="about-intro section py-20">
	<div class="col-span-12">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-4xl font-bold mb-8 font-display">
				{lang === 'es' ? 'Apasionado por la Tecnología' : 'Passionate About Technology'}
			</h2>
			<div class="space-y-6 text-lg text-slate-600">
				{lang === 'es' ? (
					<>
						<p>
							Soy <strong>Andres Vargas</strong>, un Desarrollador Full-Stack y Especialista en Seguridad con sede en <strong>Cochabamba, Bolivia</strong>. 
							Con más de 5 años de experiencia, me especializo en crear aplicaciones web robustas y escalables que generan un impacto real.
						</p>
						<p>
							Mi trayectoria en tecnología ha sido impulsada por la pasión por resolver problemas complejos y construir soluciones que conecten la excelencia técnica con el valor empresarial. Me considero un profesional versátil con experiencia en marketing digital, análisis de datos y seguridad de la información.
						</p>
					</>
				) : (
					<>
						<p>
							I'm <strong>Andres Vargas</strong>, a dedicated Full-Stack Developer and Security Specialist based in <strong>Cochabamba, Bolivia</strong>. 
							With over 5 years of experience, I specialize in creating robust, scalable web applications that make a real impact.
						</p>
						<p>
							My journey in technology has been driven by a passion for solving complex problems and building solutions that bridge the gap between technical excellence and business value. I consider myself a versatile professional with experience in digital marketing, data analysis, and information security.
						</p>
					</>
				)}
			</div>
		</div>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { SplitText } from "gsap/SplitText";

	gsap.registerPlugin(ScrollTrigger, SplitText);

	function init() {
		// Split headings for character animation
		const headingSplit = new SplitText(".about-intro h2", { type: "chars" });
		
		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: '.about-intro',
				start: "top 80%",
				toggleActions: "play none none reverse"
			}
		});

		tl.from(headingSplit.chars, {
			duration: 0.6,
			opacity: 0,
			scale: 0,
			y: 20,
			rotationX: 90,
			transformOrigin: "0% 50% -50",
			ease: "back.out",
			stagger: 0.02
		})
		.from('.about-intro p', {
			duration: 1,
			y: 30,
			opacity: 0,
			ease: "power3.out",
			stagger: 0.2
		}, "-=0.4");
	}

	document.addEventListener("DOMContentLoaded", init);
</script>
